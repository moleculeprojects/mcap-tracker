# Ignore everything by default
*

# Allow the mcap-tracker folder and its contents
!mcap-tracker/
!mcap-tracker/**

# Allow the .gitignore file itself
!.gitignore

# Node (Specific ignores for mcap-tracker if needed)
mcap-tracker/node_modules/
mcap-tracker/.env

# Local Databases (Specific ignores)
mcap-tracker/*.db
mcap-tracker/*.db-journal
mcap-tracker/*.db-wal

# Playwright / Browser Cache (Specific ignores)
mcap-tracker/playwright/
mcap-tracker/.web-cache/
mcap-tracker/test-results/
mcap-tracker/playwright-report/
mcap-tracker/blob-report/
mcap-tracker/playwright/.cache/
